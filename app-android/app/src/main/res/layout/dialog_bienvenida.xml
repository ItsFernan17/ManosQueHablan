<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/fondo_popup_redondeado">
    
    <!-- Todo el contenido es scrolleable, incluyendo el botón -->
    <ScrollView 
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/txtTituloBienvenida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Bienvenido a Manos Que Hablan"
                android:textSize="20sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Para que la aplicación funcione correctamente, ten en cuenta lo siguiente:"
                android:textSize="16sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_regular"
                android:layout_marginBottom="16dp" />

            <!-- Punto 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mantén una distancia mínima de 35 cm entre tus manos y el teléfono para mejores resultados."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Asegúrate de estar en un lugar con buena iluminación frontal (evita contraluz)."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Coloca tus manos dentro del recuadro que aparece en pantalla y manténlas estables."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="La app ajusta automáticamente el ángulo, pero procura no girar demasiado el dispositivo."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Sección importante -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/fondo_importante"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Importante:"
                    android:textSize="16sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="La aplicación puede fallar en la traducción si no se cumplen estas condiciones. Manos Que Hablan no se hace responsable de errores de interpretación si no se siguen estas recomendaciones."
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Botón Aceptar (también scrolleable) -->
            <LinearLayout
                android:id="@+id/btnAceptarBienvenida"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="12dp"
                android:paddingHorizontal="20dp"
                android:background="@drawable/boton_redondeado_aceptar"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entendido"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>