<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Icono de advertencia -->
    <ImageView
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:src="@drawable/warning"
        app:tint="@color/sunset_orange"
        android:layout_marginBottom="16dp"
        xmlns:app="http://schemas.android.com/apk/res-auto" />

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Video no traducido correctamente"
        android:textSize="20sp"
        android:textColor="@color/texto_videos"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Mensaje principal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="El sistema no pudo generar la traducción de audio y texto para este video."
        android:textSize="16sp"
        android:textColor="@color/texto_videos"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Recordatorios para mejorar -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Para mejorar la traducción, recuerda:"
        android:textSize="15sp"
        android:textColor="@color/violeta"
        android:fontFamily="@font/poppins_semibold"
        android:layout_marginBottom="12dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:maxHeight="200dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Punto 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="14sp"
                    android:textColor="@color/sunset_orange"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mantén distancia de 30-40 cm del teléfono"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="14sp"
                    android:textColor="@color/sunset_orange"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Usa buena luz frontal y evita contraluz"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="14sp"
                    android:textColor="@color/sunset_orange"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mantén las manos dentro del recuadro"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="14sp"
                    android:textColor="@color/sunset_orange"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Haz la seña despacio y con estabilidad"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Botón Entendido -->
        <TextView
            android:id="@+id/btnEntendido"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Entendido"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="@font/poppins_semibold"
            android:background="@drawable/boton_principal_rounded"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
