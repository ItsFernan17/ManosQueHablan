<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Fondo con gradiente animado -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#F5F5F5"
                android:centerColor="#E8E8E8"
                android:endColor="#F5F5F5"
                android:angle="45"
                android:type="linear" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Overlay con patrón sutil -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#10000000"
                android:endColor="#05000000"
                android:angle="90" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- Ícono central de lengua de señas -->
    <item
        android:width="32dp"
        android:height="32dp"
        android:gravity="center">
        <vector
            android:width="32dp"
            android:height="32dp"
            android:viewportWidth="24"
            android:viewportHeight="24">
            
            <!-- Mano base -->
            <path
                android:fillColor="#BDBDBD"
                android:pathData="M12,2C10.9,2 10,2.9 10,4v8c0,1.1 0.9,2 2,2s2,-0.9 2,-2V4C14,2.9 13.1,2 12,2z" />
            
            <!-- Dedos -->
            <path
                android:fillColor="#BDBDBD"
                android:pathData="M8,6C6.9,6 6,6.9 6,8v4c0,1.1 0.9,2 2,2s2,-0.9 2,-2V8C10,6.9 9.1,6 8,6z" />
            
            <path
                android:fillColor="#BDBDBD"
                android:pathData="M16,6c-1.1,0 -2,0.9 -2,2v4c0,1.1 0.9,2 2,2s2,-0.9 2,-2V8C18,6.9 17.1,6 16,6z" />
            
            <!-- Pulgar -->
            <path
                android:fillColor="#BDBDBD"
                android:pathData="M4,10c-1.1,0 -2,0.9 -2,2v2c0,1.1 0.9,2 2,2s2,-0.9 2,-2v-2C6,10.9 5.1,10 4,10z" />
            
            <path
                android:fillColor="#BDBDBD"
                android:pathData="M20,10c-1.1,0 -2,0.9 -2,2v2c0,1.1 0.9,2 2,2s2,-0.9 2,-2v-2C22,10.9 21.1,10 20,10z" />
            
            <!-- Círculo para indicar carga -->
            <path
                android:fillColor="#9E9E9E"
                android:pathData="M12,16m-3,0a3,3 0,1 1,6 0a3,3 0,1 1,-6 0"
                android:fillAlpha="0.3" />
                
        </vector>
    </item>
    
</layer-list>
