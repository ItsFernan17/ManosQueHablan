<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Recientes -->
    <LinearLayout
        android:id="@+id/opcion_recientes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingHorizontal="8dp"
        android:tag="recientes">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/recientes"
            app:tint="@color/rojo" />

        <TextView
            android:id="@+id/texto_recientes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ver videos recientes"
            android:textSize="16sp"
            android:textColor="@color/rojo"
            android:fontFamily="@font/poppins_regular" />

        <ImageView
            android:id="@+id/check_recientes"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/check"
            app:tint="@color/rojo"
            android:visibility="visible" />
    </LinearLayout>

    <!-- Alfabético -->
    <LinearLayout
        android:id="@+id/opcion_alfabetico"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingHorizontal="8dp"
        android:tag="alfabetico">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/alfabeticamente"
            app:tint="@color/texto_videos" />

        <TextView
            android:id="@+id/texto_alfabetico"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ver por orden alfabetico"
            android:textSize="16sp"
            android:textColor="@color/texto_videos"
            android:fontFamily="@font/poppins_regular" />

        <ImageView
            android:id="@+id/check_alfabetico"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/check"
            app:tint="@color/rojo"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Fecha -->
    <LinearLayout
        android:id="@+id/opcion_fecha"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingVertical="12dp"
        android:paddingHorizontal="8dp"
        android:tag="fecha">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="12dp"
            android:src="@drawable/fecha"
            app:tint="@color/texto_videos" />

        <TextView
            android:id="@+id/texto_fecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ver por fecha"
            android:textSize="16sp"
            android:textColor="@color/texto_videos"
            android:fontFamily="@font/poppins_regular" />

        <ImageView
            android:id="@+id/check_fecha"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/check"
            app:tint="@color/rojo"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
