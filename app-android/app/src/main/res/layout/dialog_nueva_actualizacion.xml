<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/contenedorModal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/fondo_popup_redondeado">
    
    <!-- Todo el contenido es scrolleable, incluyendo el botón -->
    <ScrollView 
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/txtTituloActualizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nueva Actualización 1.1.0"
                android:textSize="20sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Tenemos contenido nuevo para ti! Hemos agregado una categoría especial para expandir tu vocabulario."
                android:textSize="16sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Nueva Categoría Verbos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nueva Categoría: Verbos"
                    android:textSize="20sp"
                    android:textColor="@color/primary_color"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cantar • Jugar • Desconectar • Ser • Estudiar"
                    android:textSize="16sp"
                    android:textColor="@color/accent_color"
                    android:fontFamily="@font/poppins_medium"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aprende los verbos más importantes en lengua de señas con videos especializados que te ayudarán a comunicarte mejor."
                    android:textSize="15sp"
                    android:textColor="@color/texto_secundario"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Optimización del Servicio de IA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Optimización del Servicio de IA"
                    android:textSize="17sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Corrección del problema donde la IA detectaba dos señas en una sola, mejorando la precisión del reconocimiento"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Optimización General de la Aplicación -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Optimización General"
                    android:textSize="17sp"
                    android:textColor="@color/primary_color"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mejoras en el rendimiento general para una experiencia más rápida y estable"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Arreglo de Bugs Generales -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Arreglo de Bugs Generales"
                    android:textSize="17sp"
                    android:textColor="@color/texto_secundario"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Corrección de errores menores para mejorar la estabilidad y funcionalidad"
                    android:textSize="14sp"
                    android:textColor="@color/texto_secundario"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Sección destacada -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/fondo_importante"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txtDestacado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¡Empieza a Practicar!"
                    android:textSize="17sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="10dp" />

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:background="@color/accent_color"
                    android:layout_gravity="center"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Encuentra la categoría Verbos en Catálogo de Señas desde el menú principal"
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Botón Aceptar -->
            <LinearLayout
                android:id="@+id/btnAceptarActualizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="14dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/boton_redondeado_aceptar"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entendido"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>