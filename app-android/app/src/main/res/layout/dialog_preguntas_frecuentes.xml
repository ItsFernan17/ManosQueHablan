<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Header con título -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/txtTituloPreguntasFrecuentes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Preguntas Frecuentes"
            android:textColor="@color/rojo"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center" />

    </RelativeLayout>

    <!-- Contenido del diálogo -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Pregunta 1 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué significa el tag 'mal traducido'?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cuando la aplicación marca un video como 'mal traducido', significa que las señas no se realizaron correctamente y la traducción generada por la IA no fue precisa."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta 2 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Cómo funciona la traducción?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="La app usa Inteligencia Artificial entrenada con Lengua de Señas Guatemalteca (LSG) para analizar los gestos y generar traducción en voz y texto."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta 3 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿La app comparte mis videos sin preguntar?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los videos solo se comparten cuando presionas el botón. Si la app detecta un video 'mal traducido', primero te preguntará si deseas enviarlo. Esta opción puede desactivarse en la configuración."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta 4 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué es la Lengua de Señas Guatemalteca?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Es la lengua de señas usada en Guatemala, distinta a otras como ASL o LSM, por lo que necesita un modelo de IA específico."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta 5 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Cómo mejorar la precisión de la traducción?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• Graba en un lugar bien iluminado\n• Mantén las manos visibles en todo momento\n• Realiza las señas de forma clara y pausada\n• Evita movimientos bruscos de fondo"
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Pregunta 6 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Qué pasa si pierdo conexión a internet?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Puedes grabar videos sin internet. Si intentas traducirlos sin conexión, la app intentará conectarse y, si falla, te avisará que no hay conexión. No es posible enviarlos más tarde sin internet."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="24dp" />

            <!-- Pregunta 7 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¿Puedo salir de la app mientras se procesa un video?"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sí, puedes salir de la app y usar otras aplicaciones mientras se procesa el video. Solo evita cerrarla por completo desde recientes, ya que eso interrumpirá el proceso."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="24dp" />


            <!-- Botón Aceptar -->
            <LinearLayout
                android:id="@+id/btnAceptarPreguntasFrecuentes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="32dp"
                android:background="@drawable/boton_redondeado_aceptar"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Entendido"
                    android:textAlignment="center"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>