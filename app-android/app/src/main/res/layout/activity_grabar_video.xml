<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Fondo para la vista de cámara -->
    <View
        android:id="@+id/fondoCamara"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1A000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Vista previa de la cámara -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ProgressBar
        android:id="@+id/progressCamara"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminateTint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Header superior reorganizado -->
    <LinearLayout
        android:id="@+id/headerTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="8dp"
        android:paddingTop="16dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textIndicaciones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/boton_cuadrado_redondeado"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:minWidth="200dp"
            android:maxWidth="400dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Coloca tus manos dentro del marco"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:maxLines="1"
            android:singleLine="true"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Botón cerrar - IZQUIERDA -->
            <ImageView
                android:id="@+id/btnCerrar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/boton_cuadrado_redondeado"
                android:contentDescription="Cerrar"
                android:padding="12dp"
                android:src="@drawable/icono_cerrar" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Temporizador - CENTRO -->
            <TextView
                android:id="@+id/temporizador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/contador_background"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:minWidth="80dp"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="00:00"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

            <!-- Indicador de exposición (sutil) -->
            <TextView
                android:id="@+id/exposureIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/boton_cuadrado_redondeado"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="●"
                android:textColor="#90FFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Botón rotar cámara - DERECHA -->
            <ImageView
                android:id="@+id/btnRotarCamara"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/boton_cuadrado_redondeado"
                android:contentDescription="Rotar cámara"
                android:padding="12dp"
                android:src="@drawable/rotacion"
                app:tint="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

    <!-- Contenedor del marco de manos con banner superpuesto -->
    <FrameLayout
        android:id="@+id/handGuideFrame"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerTop"
        app:layout_constraintBottom_toTopOf="@id/controlesInferiores"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_max="280dp"
        app:layout_constraintHeight_max="450dp"
        app:layout_constraintDimensionRatio="H,280:450">

        <View
            android:id="@+id/guiaManos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:background="@drawable/marco_manos_guia" />

    </FrameLayout>

    <!-- Controles inferiores estilo iPhone -->
    <FrameLayout
        android:id="@+id/controlesInferiores"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Botón eliminar (oculto) -->
        <ImageView
            android:id="@+id/btnEliminar"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@drawable/icono_papelera"
            android:contentDescription="Eliminar"
            android:background="@drawable/boton_cuadrado_redondeado"
            android:padding="16dp"
            android:visibility="gone"
            android:layout_gravity="start|center_vertical" />

        <!-- Botón grabar principal ABSOLUTAMENTE CENTRADO -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center">

            <!-- Círculo exterior -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circulo_grabar_exterior" />

            <!-- Botón grabar -->
            <ImageView
                android:id="@+id/btnGrabar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/circulo"
                android:contentDescription="Grabar"
                app:tint="#FF0000" />

            <!-- Overlay de pausa para indicar que está deshabilitado -->
            <View
                android:id="@+id/overlayPausa"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/circulo_negro_transparente"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Botón pausar posicionado independientemente a la derecha -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="16dp">

            <ImageView
                android:id="@+id/btnPausar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/icono_pausar"
                android:contentDescription="Pausar"
                android:background="@drawable/boton_cuadrado_redondeado"
                android:padding="16dp" />

            <!-- Indicador de pausa -->
            <TextView
                android:id="@+id/indicadorPausa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:background="@drawable/contador_pausa_background"
                android:text="PAUSA"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:fontFamily="@font/poppins_bold"
                android:paddingHorizontal="4dp"
                android:paddingVertical="2dp"
                android:visibility="gone" />

        </FrameLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>