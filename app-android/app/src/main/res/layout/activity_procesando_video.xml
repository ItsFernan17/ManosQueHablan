<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- Círculos animados de fondo (solo círculos) -->
    <ImageView
        android:id="@+id/circle1"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:layout_marginTop="80dp"
        android:src="@drawable/circle_celeste"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle2"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="30dp"
        android:layout_marginTop="150dp"
        android:src="@drawable/circle_violeta"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle3"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="100dp"
        android:src="@drawable/circle_rosa"
        android:alpha="0.3" />

    <ImageView
        android:id="@+id/circle4"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="150dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_verde"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle5"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="80dp"
        android:layout_marginTop="50dp"
        android:src="@drawable/circle_celeste"
        android:alpha="0.3" />

    <ImageView
        android:id="@+id/circle6"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="120dp"
        android:layout_marginBottom="250dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_verde"
        android:alpha="0.3" />

    <ImageView
        android:id="@+id/circle7"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="15dp"
        android:layout_marginBottom="200dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_rosa"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle8"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="100dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_violeta"
        android:alpha="0.5" />

    <ImageView
        android:id="@+id/circle9"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="80dp"
        android:layout_marginTop="300dp"
        android:src="@drawable/circle_celeste"
        android:alpha="0.4" />

    <!-- Círculos adicionales con colores bonitos -->
    <ImageView
        android:id="@+id/circle10"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="30dp"
        android:layout_marginTop="120dp"
        android:src="@drawable/circle_coral"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/circle11"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="40dp"
        android:layout_marginTop="80dp"
        android:src="@drawable/circle_mint"
        android:alpha="0.5" />

    <ImageView
        android:id="@+id/circle12"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="280dp"
        android:layout_marginBottom="320dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_lavender"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle13"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="120dp"
        android:layout_marginBottom="80dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_peach"
        android:alpha="0.6" />

    <ImageView
        android:id="@+id/circle14"
        android:layout_width="35dp"
        android:layout_height="35dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="180dp"
        android:layout_marginTop="40dp"
        android:src="@drawable/circle_sky_blue"
        android:alpha="0.5" />

    <ImageView
        android:id="@+id/circle15"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="60dp"
        android:layout_marginBottom="180dp"
        android:layout_alignParentBottom="true"
        android:src="@drawable/circle_soft_pink"
        android:alpha="0.4" />

    <ImageView
        android:id="@+id/circle16"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="180dp"
        android:layout_marginTop="180dp"
        android:src="@drawable/circle_turquoise"
        android:alpha="0.5" />

    <ImageView
        android:id="@+id/circle17"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="320dp"
        android:layout_marginTop="220dp"
        android:src="@drawable/circle_coral"
        android:alpha="0.3" />

    <ImageView
        android:id="@+id/circle18"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_alignParentStart="true"
        android:layout_marginStart="20dp"
        android:layout_marginTop="350dp"
        android:src="@drawable/circle_mint"
        android:alpha="0.6" />

    <!-- Contenido principal centrado -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Miniatura de video estilo app móvil moderna -->
        <androidx.cardview.widget.CardView
            android:layout_width="320dp"
            android:layout_height="180dp"
            android:layout_marginBottom="40dp"
            app:cardCornerRadius="24dp"
            app:cardBackgroundColor="@color/white"
            app:cardElevation="0dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- Dark navy gradient background -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/dark_navy_gradient_background" />

                <!-- Imagen de captura del video con blur total -->
                <ImageView
                    android:id="@+id/videoPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:alpha="0.3" />

                <!-- 70% Black overlay for very dark look -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/dark_overlay_70" />

                <!-- Puntos de carga superpuestos en el centro de la miniatura -->
                <LinearLayout
                    android:id="@+id/loadingDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <View
                        android:id="@+id/dot1"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/loading_dot_celeste" />

                    <View
                        android:id="@+id/dot2"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/loading_dot_celeste" />

                    <View
                        android:id="@+id/dot3"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:background="@drawable/loading_dot_celeste" />

                </LinearLayout>

            </FrameLayout>

        </androidx.cardview.widget.CardView>

        <!-- Texto "Procesando video..." -->
        <TextView
            android:id="@+id/txtProcesando"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Procesando video..."
            android:textSize="24sp"
            android:textColor="@color/texto_principal"
            android:fontFamily="@font/poppins_semibold"
            android:layout_marginBottom="16dp"
            android:gravity="center" />

        <!-- Texto adicional pequeño -->
        <TextView
            android:id="@+id/txtMensajeSalir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Puedes salir de la app mientras se procesa el video."
            android:textSize="14sp"
            android:textColor="@color/texto_secundario"
            android:fontFamily="@font/poppins_regular"
            android:layout_marginBottom="30dp"
            android:gravity="center" />

        <!-- Circular Progress Indicator Material Design -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="center">

            <!-- CircularProgressIndicator como anillo exterior -->
            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/circularProgressIndicator"
                android:layout_width="140dp"
                android:layout_height="140dp"
                android:progress="75"
                app:indicatorColor="@color/progress_indicator"
                app:trackColor="@color/progress_track"
                app:indicatorSize="140dp"
                app:trackThickness="8dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- Círculo central con ícono de cámara -->
            <FrameLayout
                android:id="@+id/centerCircle"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/circle_center_background"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Ícono de cámara blanco centrado -->
                <ImageView
                    android:id="@+id/cameraIcon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_videocam_24"
                    android:contentDescription="@string/app_name" />

            </FrameLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

</RelativeLayout>
