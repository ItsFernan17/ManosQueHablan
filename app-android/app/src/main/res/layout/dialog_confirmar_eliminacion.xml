<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="24dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"
    android:background="@android:color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@color/background">

        <!-- Título -->
        <TextView
            android:id="@+id/txtTituloEliminar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Eliminar este video?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAlignment="center"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/texto_videos"
            android:layout_marginBottom="8dp" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/txtDescripcionEliminar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Esta acción eliminará el video por completo. ¿Deseas continuar?"
            android:textAlignment="center"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_regular"
            android:textColor="@color/texto_videos"
            android:layout_marginBottom="20dp" />

        <!-- Botones -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnCancelarEliminar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/boton_redondeado_cancelar"
                android:fontFamily="@font/poppins_medium"
                android:textSize="14sp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp" />

            <Button
                android:id="@+id/btnConfirmarEliminar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Eliminar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:background="@drawable/boton_redondeado_aceptar"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/poppins_medium"
                android:textSize="14sp"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
