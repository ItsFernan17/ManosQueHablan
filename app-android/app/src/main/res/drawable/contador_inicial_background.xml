<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Sombra exterior -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#40000000" />
            <corners android:radius="20dp" />
            <padding
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp" />
        </shape>
    </item>
    
    <!-- Fondo principal con gradiente -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:centerColor="#F8F9FA"
                android:endColor="#E9ECEF"
                android:angle="135" />
            <corners android:radius="18dp" />
            <stroke
                android:width="1.5dp"
                android:color="#6C757D" />
        </shape>
    </item>
    
    <!-- Borde interior decorativo -->
    <item android:left="1.5dp" android:top="1.5dp" android:right="1.5dp" android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:endColor="#F1F3F4"
                android:angle="45" />
            <corners android:radius="16.5dp" />
        </shape>
    </item>
    
    <!-- Punto decorativo superior izquierdo -->
    <item android:left="8dp" android:top="8dp">
        <shape android:shape="oval">
            <solid android:color="#E3F2FD" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
    <!-- Punto decorativo inferior derecho -->
    <item android:right="8dp" android:bottom="8dp">
        <shape android:shape="oval">
            <solid android:color="#E8F5E8" />
            <size android:width="4dp" android:height="4dp" />
        </shape>
    </item>
    
</layer-list>
