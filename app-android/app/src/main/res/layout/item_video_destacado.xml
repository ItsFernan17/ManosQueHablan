<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingBottom="12dp">

            <TextView
                android:id="@+id/txtTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Texto muy largo que se desplazará"
                android:textColor="@color/texto_videos"
                android:textSize="16sp"
                android:ellipsize="marquee"
                android:singleLine="true"
                android:marqueeRepeatLimit="marquee_forever"
                android:scrollHorizontally="true"
                android:textAlignment="center"
                android:clickable="true"
                android:focusable="false"
                android:focusableInTouchMode="false"
                />

            <TextView
                android:id="@+id/txtFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hoy"
                android:textColor="@color/texto_videos"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular" />

            <!-- Etiqueta de mal traducido -->
            <TextView
                android:id="@+id/etiquetaMalTraducido"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MAL TRADUCIDO"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:fontFamily="@font/poppins_bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:background="@drawable/fondo_advertencia_redondeado"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Contenido: miniatura + acciones -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Miniatura con botón reproducir -->
            <FrameLayout
                android:id="@+id/frameMiniatura"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginEnd="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintWidth_percent="0.40"
                app:layout_constraintDimensionRatio="1:1">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imgMiniatura"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    app:shapeAppearanceOverlay="@style/RoundedMiniaturaStyle" />

                <ImageView
                    android:id="@+id/btnReproducir"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/reproducir"
                    app:tint="@android:color/white" />
            </FrameLayout>

            <!-- Contenedor de acciones -->
            <LinearLayout
                android:id="@+id/contenedorAcciones"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                app:layout_constraintStart_toEndOf="@id/frameMiniatura"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <!-- Exportar -->
                <LinearLayout
                    android:id="@+id/exportarContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/btnExportar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/compartir"
                        app:tint="@color/violeta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Compartir Video"
                        android:textColor="@color/texto_videos"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Ver Traducción -->
                <LinearLayout
                    android:id="@+id/verTraduccionContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/btnVerTraduccion"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/ver"
                        app:tint="@color/violeta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ver Texto Traducido"
                        android:textColor="@color/texto_videos"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Escuchar -->
                <LinearLayout
                    android:id="@+id/escucharContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/btnEscuchar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/escuchar"
                        app:tint="@color/violeta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Escuchar Traducción"
                        android:textColor="@color/texto_videos"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Eliminar -->
                <LinearLayout
                    android:id="@+id/eliminarContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/btnEliminar"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:src="@drawable/eliminar"
                        app:tint="@color/violeta" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Eliminar Video"
                        android:textColor="@color/texto_videos"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_regular"
                        android:maxLines="1"
                        android:ellipsize="end" />
                </LinearLayout>

            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
