<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Header con título -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/txtTituloAcercaDe"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Acerca de Manos Que Hablan"
            android:textColor="@color/rojo"
            android:textSize="20sp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center" />

    </RelativeLayout>

    <!-- Contenido del diálogo -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Descripción principal -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manos Que Hablan es una aplicación que traduce la Lengua de Señas Guatemalteca (LSG) a voz y texto en videos mediante Inteligencia Artificial, promoviendo la inclusión y la comunicación accesible entre la comunidad sorda y oyente en Guatemala."
                android:textColor="@color/texto_videos"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="4dp"
                android:layout_marginBottom="18dp" />

            <!-- Agradecimientos -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Agradecimientos:"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Se agradece al Benemérito Comité Pro Ciegos y Sordos de Guatemala por su valioso apoyo y colaboración en el entrenamiento del modelo de IA."                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Privacidad -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Privacidad:"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Los videos grabados únicamente se utilizan con fines de traducción y no se comparten con terceros."
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Contacto -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contacto:"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="manosquehablan.app@gmail.com"
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="18dp" />

            <!-- Versión -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Versión:"
                android:textColor="@color/rojo"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_medium"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1.1.0"
                android:textColor="@color/texto_videos"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_regular"
                android:lineSpacingExtra="3dp"
                android:layout_marginBottom="24dp" />

            <!-- Botón Aceptar -->
            <LinearLayout
                android:id="@+id/btnAceptar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="32dp"
                android:background="@drawable/boton_redondeado_aceptar"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Aceptar"
                    android:textAlignment="center"
                    android:textColor="@android:color/white"
                    android:textSize="16sp" />
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>