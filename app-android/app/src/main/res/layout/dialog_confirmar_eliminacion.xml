<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Header con título -->
    <RelativeLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtTituloEliminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="¿Eliminar este video?"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins_bold"
            android:textColor="@color/texto_videos"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeMaxTextSize="18sp"
            app:autoSizeStepGranularity="2sp" />

    </RelativeLayout>

    <!-- Subtítulo -->
    <TextView
        android:id="@+id/txtDescripcionEliminar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Esta acción eliminará el video por completo. ¿Deseas continuar?"
        android:textAlignment="center"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_regular"
        android:textColor="@color/texto_videos"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toTopOf="@id/actionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Barra de acciones fija -->
    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelarEliminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/boton_redondeado_cancelar"
            android:fontFamily="@font/poppins_medium"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:minWidth="88dp"
            android:minHeight="48dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmarEliminar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Eliminar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/boton_redondeado_aceptar"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/poppins_medium"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:minWidth="88dp"
            android:minHeight="48dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
