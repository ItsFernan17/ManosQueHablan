<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package="com.frivasm.manosquehablan">

    <!-- Permisos de cámara y micrófono -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Acceso a Internet para comunicar con la API -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Permisos de almacenamiento según versión de Android -->

    <!-- Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- Android 10 a 12 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Característica opcional de cámara -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/logo"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/logo"
        android:supportsRtl="true"
        android:theme="@style/Theme.ManosQueHablan">

        <!-- Actividades -->

        <activity
            android:name=".DialogLoadingActivity"
            android:exported="false" />

        <activity
            android:name=".GrabarVideoActivity"
            android:exported="false"
            android:screenOrientation="sensor" />

        <activity
            android:name=".InicioAppActivity"
            android:exported="false" />

        <activity
            android:name=".InicioSplashScreenActivity"
            android:exported="true"
            android:theme="@style/Theme.ManosQueHablan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.ManosQueHablan" />
    </application>

</manifest>
