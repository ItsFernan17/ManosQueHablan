<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Título -->
    <TextView
        android:id="@+id/txtTituloRecordatorio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/titulo_antes_de_grabar"
        android:textSize="20sp"
        android:textColor="@color/texto_videos"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:maxHeight="300dp">

        <LinearLayout
            android:id="@+id/contenidoDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Punto 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mantén tus manos a 30-40 cm del teléfono."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Usa buena luz frontal y evita contraluz. Toca la pantalla para ajustar el brillo manualmente."
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/consejo_recuadro"
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/consejo_estabilidad"
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Punto 5 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="• "
                    android:textSize="16sp"
                    android:textColor="@color/violeta"
                    android:fontFamily="@font/poppins_semibold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/consejo_angulo"
                    android:textSize="15sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

            <!-- Sección importante -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/fondo_importante"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/titulo_importante"
                    android:textSize="16sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_semibold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/mensaje_importante"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Botones -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <!-- Botón Siguiente -->
        <LinearLayout
            android:id="@+id/btnSiguienteRecordatorio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:paddingHorizontal="20dp"
            android:background="@drawable/boton_redondeado_aceptar"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_siguiente"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_semibold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
