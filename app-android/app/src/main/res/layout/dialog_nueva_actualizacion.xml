<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/contenedorModal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/fondo_popup_redondeado">
    
    <!-- Todo el contenido es scrolleable, incluyendo el botón -->
    <ScrollView 
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:fillViewport="false"
        android:overScrollMode="ifContentScrolls"
        android:scrollbars="vertical"
        android:fadeScrollbars="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/txtTituloActualizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nueva Actualización 1.1.0"
                android:textSize="20sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="¡Tenemos contenido nuevo para ti! Hemos agregado una categoría especial para expandir tu vocabulario."
                android:textSize="16sp"
                android:textColor="@color/texto_videos"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Nueva Categoría Verbos -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/celeste" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Nueva Categoría: Verbos"
                        android:textSize="16sp"
                        android:textColor="@color/primary_color"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cantar • Jugar • Desconectar • Ser • Estudiar"
                        android:textSize="14sp"
                        android:textColor="@color/accent_color"
                        android:fontFamily="@font/poppins_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- Optimización del Servicio de IA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/violeta" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mejora en IA"
                        android:textSize="16sp"
                        android:textColor="@color/violeta"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Corrección de detección múltiple de señas"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"
                        android:fontFamily="@font/poppins_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- Optimización General -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/card_background"
                android:padding="16dp"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_info"
                    android:layout_marginEnd="12dp"
                    app:tint="@color/primary_color" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Optimización General"
                        android:textSize="16sp"
                        android:textColor="@color/primary_color"
                        android:fontFamily="@font/poppins_semibold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Mejoras en rendimiento y estabilidad"
                        android:textSize="14sp"
                        android:textColor="@color/texto_secundario"
                        android:fontFamily="@font/poppins_regular" />
                </LinearLayout>
            </LinearLayout>

            <!-- Sección destacada -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/fondo_importante"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/txtDestacado"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¡Descubre los Verbos!"
                    android:textSize="16sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_semibold"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ve al Catálogo de Señas → Verbos"
                    android:textSize="14sp"
                    android:textColor="@color/texto_videos"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Botón Aceptar -->
            <LinearLayout
                android:id="@+id/btnAceptarActualizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingVertical="14dp"
                android:paddingHorizontal="24dp"
                android:background="@drawable/boton_redondeado_aceptar"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Entendido"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_semibold" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>