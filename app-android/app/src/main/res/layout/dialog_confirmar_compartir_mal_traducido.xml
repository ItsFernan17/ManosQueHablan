<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_popup_redondeado">

    <!-- Header con título -->
    <RelativeLayout
        android:id="@+id/headerContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Icono de advertencia -->
        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_centerHorizontal="true"
            android:src="@drawable/warning"
            app:tint="@color/sunset_orange"
            android:layout_marginBottom="16dp" />

    </RelativeLayout>

    <!-- Contenido scrollable -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toBottomOf="@id/headerContainer"
        app:layout_constraintBottom_toTopOf="@id/actionsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Título -->
            <TextView
                android:id="@+id/txtTituloConfirmarCompartir"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/confirmar_compartir_titulo"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/texto_videos"
                android:layout_marginBottom="8dp"
                android:maxLines="2"
                android:ellipsize="end"
                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="14sp"
                app:autoSizeMaxTextSize="18sp"
                app:autoSizeStepGranularity="2sp" />

            <!-- Mensaje -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/confirmar_compartir_mensaje"
                android:textAlignment="center"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_regular"
                android:textColor="@color/texto_videos" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Barra de acciones fija -->
    <LinearLayout
        android:id="@+id/actionsContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp"
        android:background="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCancelarCompartir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancelar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/boton_redondeado_cancelar"
            android:fontFamily="@font/poppins_medium"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:minWidth="88dp"
            android:minHeight="48dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmarCompartir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/compartir"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:background="@drawable/boton_redondeado_aceptar"
            android:layout_marginStart="16dp"
            android:fontFamily="@font/poppins_medium"
            android:textSize="14sp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="10dp"
            android:minWidth="88dp"
            android:minHeight="48dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>