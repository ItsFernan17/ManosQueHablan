<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/dialog_rounded_background"
    android:padding="24dp"
    android:gravity="center">

    <!-- Icono más amigable con animación -->
    <ImageView
        android:id="@+id/iconoError"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_info"
        android:layout_marginBottom="20dp"
        app:tint="@color/accent_color" />

    <!-- Título del error más amigable -->
    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/conexion_problema"
        android:textSize="22sp"
        android:textColor="@color/texto_principal"
        android:fontFamily="@font/poppins_semibold"
        android:layout_marginBottom="15dp"
        android:gravity="center" />

    <!-- Mensaje del error -->
    <TextView
        android:id="@+id/txtMensaje"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/error_conexion_servidor"
        android:textSize="16sp"
        android:textColor="@color/texto_secundario"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="20dp"
        android:gravity="center"
        android:textAlignment="center"
        android:lineSpacingExtra="4dp" />

    <!-- Sugerencia amigable -->
    <TextView
        android:id="@+id/txtSugerencia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sugerencia_conexion"
        android:textSize="14sp"
        android:textColor="@color/texto_hint"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginBottom="25dp"
        android:gravity="center"
        android:textAlignment="center"
        android:lineSpacingExtra="2dp"
        android:background="@drawable/rounded_hint_background"
        android:padding="12dp" />

    <!-- Botón Aceptar -->
    <LinearLayout
        android:id="@+id/btnAceptar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="32dp"
        android:background="@drawable/boton_redondeado_aceptar"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingVertical="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_medium"
            android:text="Entendido"
            android:textAlignment="center"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>

</ScrollView>